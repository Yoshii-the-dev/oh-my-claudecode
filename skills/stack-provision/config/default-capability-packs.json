{
  "schema_version": 3,
  "discovery_policy": {
    "default_source_order": [
      "skills-sh",
      "plugin-marketplace",
      "github",
      "installed",
      "bundled"
    ],
    "cache_ttl_seconds": 21600,
    "selection_policy": {
      "max_candidates_per_run": 40,
      "max_candidates_per_cell": 3,
      "min_cell_score": 6,
      "download_requires_expected_sha256": true,
      "prefer": [
        "installed/bundled skills with matching capability packs",
        "official documentation and official GitHub organizations",
        "marketplace skills with security score, usage, license, freshness, and content checksum",
        "focused skills that cover a missing cell instead of broad kitchen-sink bundles"
      ],
      "reject": [
        "skills without previewable SKILL.md content or an expected sha256 for downloads",
        "skills that ask to override system/developer instructions",
        "skills with hidden network behavior, credential access, or destructive commands",
        "duplicates of existing local skills unless they are clearly fresher or narrower"
      ]
    },
    "skill_source_registry": [
      {
        "id": "skills-sh",
        "type": "marketplace",
        "homepage": "https://skills.sh",
        "search_method": "Browse skills.sh or provide a skills CLI/API index payload.",
        "search_url_template": "https://skills.sh/api/search?q={query}",
        "install_command_template": "npx skills add {ref}",
        "install_reference_fields": ["ref", "package", "repository", "slug", "name"],
        "domains": ["skills.sh"],
        "tags": ["claude-code", "codex", "skill.md"],
        "install_policy": "explicit-review",
        "rate_limit_rpm": 25,
        "concurrency": 2,
        "api_key_env": "SKILLS_SH_API_KEY",
        "auth_header_template": "Bearer {token}",
        "rate_limit_notes": "skills.sh advertises 30 rpm without an API key; we default to 25 to leave headroom for other concurrent stack-provision runs in the same network. Set SKILLS_SH_API_KEY to lift the limit per the official API docs."
      },
      {
        "id": "agentskill-sh",
        "type": "marketplace",
        "homepage": "https://agentskill.sh",
