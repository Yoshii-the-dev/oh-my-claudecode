{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oh-my-claudecode.local/schemas/stack-provision/contract.schema.json",
  "title": "Stack Provision Run Contract",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "created_at",
    "input",
    "stack",
    "surfaces",
    "creative_intent",
    "policy"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "input": {
      "type": "object",
      "required": ["raw"],
      "properties": {
        "raw": { "type": "string" },
        "adr_path": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "stack": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "surfaces": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "creative_intent": { "type": "string" },
    "policy": {
      "type": "object",
      "required": ["human_gate_required", "quarantine_required", "allow_generated_install_by_default"],
      "properties": {
        "human_gate_required": { "type": "boolean", "const": true },
        "quarantine_required": { "type": "boolean", "const": true },
        "allow_generated_install_by_default": { "type": "boolean" },
        "dry_run": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
