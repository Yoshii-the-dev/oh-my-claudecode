{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oh-my-claudecode.local/schemas/stack-provision/config.schema.json",
  "title": "Stack Provision Capability Config",
  "type": "object",
  "required": ["schema_version", "surfaces", "capability_packs"],
  "properties": {
    "schema_version": { "type": "integer", "const": 3 },
    "discovery_policy": {
      "type": "object",
      "properties": {
        "default_source_order": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "professional_source_domains": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "specialized_platform_domains": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "trusted_github_orgs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "query_expansions": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "source_quality_weights": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        }
      },
      "additionalProperties": true
    },
    "application_blocks": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["surface"],
        "properties": {
          "canonical": { "type": "string", "minLength": 1 },
          "surface": { "type": "string", "minLength": 1 },
          "aliases": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": true
      }
    },
    "surfaces": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["description", "default_aspects", "tech_match", "capability_packs"],
        "properties": {
          "description": { "type": "string" },
          "default_aspects": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "tech_match": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "capability_packs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "aspect_capability_packs": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "aspect_aliases": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "aspect_profiles": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["tech_match", "aspects"],
              "properties": {
                "tech_match": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                },
                "aspects": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                }
              },
              "additionalProperties": true
            }
          },
          "required_context": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": true
      }
    },
    "capability_packs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "agents": {
            "type": "array",
            "items": { "type": "string" }
          },
          "skills": {
            "type": "array",
            "items": { "type": "string" }
          },
          "optional_external": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "matching": {
      "type": "object",
      "properties": {
        "negative_rules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "slug_match": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "surfaces": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "technologies": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "aspects": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "capability_packs": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
